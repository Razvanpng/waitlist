# Supabase project credentials — get these from your project's API settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# App config
VITE_APP_NAME="Smart Waitlist"
VITE_APP_BASE_URL=http://localhost:5173

# Waitlist cascade window in minutes (used by the Edge Function — not the frontend)
# Set this as a SECRET in Supabase Dashboard > Edge Functions > Secrets
# WAITLIST_OFFER_TTL_MINUTES=10